# Arab ShipBroker — local environment template.
# Copy this file to ".env.local" and fill in the values from your Supabase project
# (Supabase dashboard → Project Settings → API).

# ── Required (the app reads exactly these) ───────────────────────────────
NEXT_PUBLIC_SUPABASE_URL=https://YOUR-PROJECT.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=YOUR-ANON-KEY
# Service role key — server-only (signup, account deletion, cron). Never exposed to the browser.
SUPABASE_SERVICE_ROLE_KEY=YOUR-SERVICE-ROLE-KEY

# ── Optional features ────────────────────────────────────────────────────
# AI circular parser / Bosun assistant (leave unset to keep it off):
# ANTHROPIC_API_KEY=sk-ant-...
# NEXT_PUBLIC_ASSISTANT_ENABLED=true
# Weekly Market-Insights cron auth (only needed if you run the cron):
# CRON_SECRET=any-long-random-string
